{
  "name": "@scribear/scribear-db",
  "version": "0.0.0",
  "description": "",
  "author": "scribear",
  "main": "dist/src/index.js",
  "type": "module",
  "imports": {
    "#src/*": "./dist/src/*",
    "#tests/*": "./dist/tests/*"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "format": "prettier --check ./src",
    "format:fix": "prettier --write ./src",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "migrate:up": "npm run build && node ./dist/src/scripts/migrate.js",
    "migrate:down": "npm run build && node ./dist/src/scripts/migrate.js down",
    "generate:types": "npm run build && node ./dist/src/scripts/generate-types.js"
  },
  "dependencies": {
    "env-schema": "7.0.0",
    "kysely": "0.28.11",
    "pg": "8.19.0",
    "typebox": "1.1.5"
  },
  "devDependencies": {
    "@types/pg": "8.16.0",
    "kysely-codegen": "0.20.0"
  }
}
