# -- Image Tags -------------
# Use "latest" for production, "staging" for staging builds, "dev" for local development
IMAGE_TAG=dev

# -- Nginx ------------------
NGINX_PORT=80
NGINX_HTTPS_PORT=443
SSL_CERT_PATH=/etc/ssl/certs/your-cert.cer
SSL_KEY_PATH=/etc/ssl/private/your-key.key

# -- Scripts -----------------
ORIGIN=https://localhost:443

# -- Database ---------------
DB_NAME=scribear-db
DB_USER=scribear
DB_PASSWORD=CHANGEME

# -- Session Manager --------
SESSION_MANAGER_LOG_LEVEL=info
SESSION_MANAGER_API_KEY=CHANGEME

# -- Node Server -----
NODE_SERVER_LOG_LEVEL=info
NODE_SERVER_KEY=CHANGEME
JWT_SECRET=CHANGEME-JWT-must-be-at-least-32-characters-long

# -- Redis ------------------
REDIS_PASSWORD=CHANGEME

# -- Transcription Service --
# "cpu" or "cuda"
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_LOG_LEVEL=info
TRANSCRIPTION_API_KEY=CHANGEME
TRANSCRIPTION_WS_INIT_TIMEOUT_SEC=2.5
PROVIDER_CONFIG_PATH=./provider_config.json
