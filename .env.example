################################################################################
# ScribeAR Docker Environment Configuration
################################################################################

################################################################################
# Database Configuration
################################################################################
DB_NAME=scribear-db
DB_USER=scribear
DB_PASSWORD=CHANGEME_secure_password_here
DB_PORT=5432

################################################################################
# Session Manager Configuration
################################################################################
SESSION_LOG_LEVEL=info
SESSION_MANAGER_PORT=8000

# JWT Configuration
# IMPORTANT: Generate a secure random string for production!
# Example: openssl rand -base64 32
JWT_SECRET=CHANGEME_your-secret-key-min-32-chars-change-me-in-production
JWT_ISSUER=scribear-session-manager
JWT_EXPIRES_IN=24h

################################################################################
# Transcription Service Configuration
################################################################################
TRANSCRIPTION_LOG_LEVEL=info
TRANSCRIPTION_PORT=8001

# API Key for transcription service authentication
# Generate a secure key for production!
TRANSCRIPTION_API_KEY=CHANGEME_your-transcription-api-key

# WebSocket initialization timeout
WS_INIT_TIMEOUT_SEC=2.5

################################################################################
# Notes
################################################################################
# 1. Copy this file to .env and update the CHANGEME values
# 2. Never commit .env to version control
# 3. For production, use strong randomly generated secrets:
#    - JWT_SECRET: openssl rand -base64 32
#    - DB_PASSWORD: openssl rand -base64 24
#    - TRANSCRIPTION_API_KEY: openssl rand -hex 32
