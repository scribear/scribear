FROM ghcr.io/astral-sh/uv:0.11.2 AS uv

FROM nvidia/cuda:12.2.2-cudnn8-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update -y && \
    apt-get install -y software-properties-common && \
    add-apt-repository ppa:deadsnakes/ppa && \
    apt-get update -y && \
    apt-get install -y python3.12 python3.12-venv curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY --from=uv /uv /usr/local/bin/uv

ENV UV_COMPILE_BYTECODE=1
ENV UV_LINK_MODE=copy
ENV UV_PROJECT_ENVIRONMENT=/app/.venv
ENV UV_PYTHON=/usr/bin/python3.12

COPY pyproject.toml uv.lock ./

RUN uv sync --frozen --no-install-project \
    --extra faster-whisper \
    --extra silero-vad

COPY src ./src

RUN uv sync --frozen --no-editable \
    --extra faster-whisper \
    --extra silero-vad

ENV HOST=0.0.0.0
ENV PORT=80
ENV PROVIDER_CONFIG_PATH=/app/provider_config.json

HEALTHCHECK --interval=30s --timeout=30s --start-period=30s --start-interval=1s --retries=3 CMD curl -f http://localhost:80/healthcheck || exit 1

CMD ["/app/.venv/bin/python", "src/index.py"]
