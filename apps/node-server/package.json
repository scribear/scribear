{
  "name": "@scribear/node-server",
  "version": "0.0.0",
  "description": "",
  "author": "scribear",
  "main": "dist/src/index.js",
  "type": "module",
  "imports": {
    "#src/*": "./dist/src/*",
    "#tests/*": "./dist/tests/*"
  },
  "scripts": {
    "build": "tsc --build",
    "start": "node ./dist/src/index.js",
    "start:dev": "node ./dist/src/index.js --dev | pino-pretty",
    "dev": "nodemon --exec 'npm run build && npm run start:dev' --watch src --watch ../../libs/base-fastify-server/src --watch ../../libs/base-schema/src --watch ../../libs/node-server-schema/src --watch ../../libs/transcription-service-client/src src/index.ts",
    "format": "prettier --check ./src ./tests",
    "format:fix": "prettier --write ./src ./tests",
    "lint": "eslint ./src ./tests",
    "lint:fix": "eslint ./src ./tests --fix",
    "test:dev": "vitest --ui --coverage",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/awilix": "8.2.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@fastify/websocket": "11.2.0",
    "awilix": "13.0.0",
    "env-schema": "7.0.0",
    "eventemitter3": "5.0.4",
    "fastify": "5.7.4",
    "fastify-plugin": "5.1.0",
    "jsonwebtoken": "9.0.3",
    "typebox": "1.1.5"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "9.0.10",
    "@types/ws": "8.18.1"
  }
}
