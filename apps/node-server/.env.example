#### Log level to use
LOG_LEVEL=info

#### Host and port server should listen on
HOST=0.0.0.0
PORT=8001

#### JWT Configuration (must match session-manager's JWT_SECRET and JWT_ISSUER)
JWT_SECRET=CHANGEME-JWT-must-be-at-least-32-characters-long

#### Transcription Service
TRANSCRIPTION_SERVICE_ADDRESS=localhost:8080
TRANSCRIPTION_SERVICE_API_KEY=your-transcription-api-key
