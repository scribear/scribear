#### Log level to use
LOG_LEVEL=info

#### Host and port server should listen on
HOST=0.0.0.0
PORT=8002

#### JWT Configuration (must match session-manager's JWT_SECRET and JWT_ISSUER)
JWT_SECRET=CHANGEME-JWT-must-be-at-least-32-characters-long

#### Transcription Service
TRANSCRIPTION_SERVICE_ADDRESS=http://localhost:8000
TRANSCRIPTION_SERVICE_API_KEY=CHANGEME

#### Redis configuration
REDIS_URL=redis://:CHANGEME@localhost:6379

#### Session Manager Connection
NODE_SERVER_KEY=CHANGEME
SESSION_MANAGER_ADDRESS=http://localhost:8001
