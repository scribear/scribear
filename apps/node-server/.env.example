#### Log level to use
LOG_LEVEL=info

#### Host and port server should listen on
HOST=0.0.0.0
PORT=8002

#### HMAC key used to verify short-lived session tokens. Must match the key
#### configured on the Session Manager. Use a long, high-entropy random
#### string in production.
SESSION_TOKEN_SIGNING_KEY=CHANGEME

#### Session Manager service this Node Server proxies session lookups to
SESSION_MANAGER_BASE_URL=http://localhost:8001
SESSION_MANAGER_SERVICE_API_KEY=CHANGEME

#### Transcription Service this Node Server forwards audio to
TRANSCRIPTION_SERVICE_BASE_URL=http://localhost:8000
TRANSCRIPTION_SERVICE_API_KEY=CHANGEME
