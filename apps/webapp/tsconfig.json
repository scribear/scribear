{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "paths": {
      "#src/*": ["./src/*"],
      "#tests/*": ["./tests/*"]
    },
    // Vite/React specific configuration
    "types": [
      "vite/client",
      "dom-speech-recognition"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": [
    "src",
    "tests",
  ],
  // Link to shared packages
  "references": [
    {
      "path": "../../libs/transcription-service-client/tsconfig.json"
    },
    {
      "path": "../../libs/base-api-client/tsconfig.json"
    },
    {
      "path": "../../libs/session-manager-schema/tsconfig.json"
    },
    {
      "path": "../../libs/session-manager-client/tsconfig.json"
    },
    {
      "path": "../../libs/node-server-schema/tsconfig.json"
    },
    {
      "path": "../../libs/node-server-client/tsconfig.json"
    },
    {
      "path": "../../libs/transcription-service-schema/tsconfig.json"
    },
    {
      "path": "../../libs/transcription-service-client/tsconfig.json"
    }
  ]
}
